<script>
require([
    "jquery",
    "Magento_Ui/js/modal/modal"
], function ($, modal) {

    var popup = modal({
        title: "Available Coupons",
        type: "popup",
        responsive: true,
        innerScroll: true,
        buttons: []
    }, $('#coupon-popup'));

    $('#open-coupon-popup').on('click', function () {
        $('#coupon-popup').modal('openModal');
    });

    $(document).on('click', '.select-coupon', function () {
        var code = $(this).data('code');
        $('#coupon_code_input').val(code);
        $('#coupon-popup').modal('closeModal');
    });

});
</script>

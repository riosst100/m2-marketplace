<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/lof-ageverification/ageverificationproducts" method="POST">
        <service class="Lof\AgeVerification\Api\AgeVerificationProductsRepositoryInterface" method="save"/>
        <resources>
            <resource ref="Lof_AgeVerification::AgeVerificationProducts_save"/>
        </resources>
    </route>
    <route url="/V1/lof-ageverification/ageverificationproducts/search" method="GET">
        <service class="Lof\AgeVerification\Api\AgeVerificationProductsRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="Lof_AgeVerification::AgeVerificationProducts_view"/>
        </resources>
    </route>
    <route url="/V1/lof-ageverification/ageverificationproducts/:customId" method="GET">
        <service class="Lof\AgeVerification\Api\AgeVerificationProductsRepositoryInterface" method="get"/>
        <resources>
            <resource ref="Lof_AgeVerification::AgeVerificationProducts_view"/>
        </resources>
    </route>
    <route url="/V1/lof-ageverification/ageverificationproducts/:customId" method="PUT">
        <service class="Lof\AgeVerification\Api\AgeVerificationProductsRepositoryInterface" method="save"/>
        <resources>
            <resource ref="Lof_AgeVerification::AgeVerificationProducts_update"/>
        </resources>
    </route>
    <route url="/V1/lof-ageverification/ageverificationproducts/:customId" method="DELETE">
        <service class="Lof\AgeVerification\Api\AgeVerificationProductsRepositoryInterface" method="deleteById"/>
        <resources>
            <resource ref="Lof_AgeVerification::AgeVerificationProducts_delete"/>
        </resources>
    </route>
</routes>

/**
 * Popup Age Verification
 *
 * @var $block \Lof\AgeVerification\Block\Popup
 * @var $helper \Lof\AgeVerification\Helper\Data
 */

$helper = $this->helper('Lof\AgeVerification\Helper\Data');

if ($currentProduct = $helper->getCurrentProduct()) {
    if ($helper->isRequiredLogin() && $helper->getCustomerIsLoggedIn()) {
        if ($helper->hasDobByCustomer()) {
            if (!$helper->isRequiredLoginAndValidAge($currentProduct)) {
                include($block->getTemplateFile('Lof_AgeVerification::prevent.phtml'));
            }
        }
    }
}

if ($block->getCurrentPages()->getIdentifier() || $block->getCurrentCategory()) {
    if ($helper->isRequiredLogin() && $helper->getCustomerIsLoggedIn()) {
        if ($helper->hasDobByCustomer()) {
            if (!$helper->isRequiredLoginAndValidAge()) {
                include($block->getTemplateFile('Lof_AgeVerification::prevent.phtml'));
            }
        }
    }
}

if ($helper->getVerifyType() === Lof\AgeVerification\Model\Config\Source\PopupVerifyType::TYPE_REQUIRE_LOGIN) {
    include($block->getTemplateFile('Lof_AgeVerification::attention.phtml'));
} else {
    include($block->getTemplateFile('Lof_AgeVerification::ageverify.phtml'));
}
?>

<?xml version="1.0" ?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
	<route url="/V1/ves-trackorder/track" method="POST">
		<service class="Ves\Trackorder\Api\TrackOrderRepositoryInterface" method="track"/>
		<resources>
			<resource ref="anonymous"/>
		</resources>
	</route>
	<route url="/V1/ves-trackorder/send" method="POST">
		<service class="Ves\Trackorder\Api\TrackOrderRepositoryInterface" method="send"/>
		<resources>
			<resource ref="anonymous"/>
		</resources>
	</route>
	<route url="/V1/lof-trackorder/mine/track" method="POST">
        <service class="Ves\Trackorder\Api\TrackOrderRepositoryInterface" method="trackMyOrder"/>
        <resources>
            <resource ref="self" />
        </resources>
		<data>
            <parameter name="customerId" force="true">%customer_id%</parameter>
        </data>
    </route>
</routes>

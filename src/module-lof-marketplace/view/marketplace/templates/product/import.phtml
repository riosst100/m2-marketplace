        MST = {
            changePage: function(page) {
                const pageSize = document.querySelector('.page-size').value;
                MST.updateHistory(page, pageSize);
            },
            changePageSize: function(size) {
                const currentPage = parseInt($('.pagination .current-page').text());
                MST.updateHistory(currentPage, size);
            },
            updateHistory: function (currentPage = 1, pageSize = 5, showLoader = true, startImport = false, afterUpload = false) {
                $.ajax({
                    type: "GET",
                    cache: false,
                    showLoader:showLoader,
                    url: "<?= $block->escapeJs($block->getUrl('*/*/updateImportHistory')) ?>",
                    data: {
                        page: currentPage,
                        size: pageSize
                    },
                    beforeSend: function () {},
                    error: function(e) {
                        $('#import_file').val('');

                        $('#error_data_validation').slideDown();

                        $('#progress-container').slideUp();
                    },
                    success: function (html) {
                        // Hide the progress bar on success
                        $('#progress-container').slideUp();
                        
                        $('#upload_history').html(html);
                        $('#upload_history').slideDown(1000);
                        $('#hide_upload_history').show();
                        $('#show_upload_history').hide();

                        var targetRow = $('#upload_history');
                        if (targetRow.length) {
                            var offset = targetRow.offset().top;
                            $('html, body').animate({
                                scrollTop: offset-200
                            }, 500); 
                        }

                        // Get all tr elements in tbody
                        if (afterUpload) {
                            $('#upload_history tbody tr:first').find('td').each(function() {
                                // For each td in the first tr, set background color
                                $(this).css('background-color', '#e5f7fe');

                                setTimeout(() => {
                                    $(this).css('background-color', 'white');
                                }, 2000);
                            });
                        }

                        if (startImport) {
                            MST.startImport();
                        }

                        // $("a#trigger").trigger('mouseenter');
                    }
                });
            },
            validateImport: function () {
                if ($('#edit_form').valid()) {
                    var fileInput = document.getElementById('import_file');
                    var filePath = fileInput.value;
                    var allowedExtensions = /(\.csv)$/i;

                    if (!allowedExtensions.exec(filePath)) {
                        alert('Only CSV files allowed.');
                        fileInput.value = ''; // Clear the input
                        return false;
                    }
                    
                    //grab all form data
                    var formData = new FormData($('#edit_form')[0]);
                    
                    // Show the progress overlay
                    $('#progress-container').slideDown(300);
                    $('#progress-text').text('Validating data...');
                    MST.updateProgressCircle(0);
                    $('#error_data_validation').slideUp();

                    $.ajax({
                        type: "POST",
                        url: "<?= $block->escapeJs($block->getUrl('*/*/validateimport/')) ?>",
                        data: formData,
                        async: true,
                        cache: false,
                        contentType: false,
                        enctype: 'multipart/form-data',
                        processData: false,
                        showLoader: false,
                        beforeSend: function () {},
                        xhr: function() {
                            var xhr = new window.XMLHttpRequest();
                            
                            // Track progress for file upload
                            if (xhr.upload) {
                                xhr.upload.addEventListener("progress", function(evt) {
                                    if (evt.lengthComputable) {
                                        var percentComplete = Math.round((evt.loaded / evt.total) * 100);
                                        MST.updateProgressCircle(percentComplete);
                                    }
                                }, false);
                            }

                            return xhr;
                        },
                        error: function(e) {
                            console.error('Upload error:', e);
                            $('#import_file').val('');
                            $('#error_data_validation').slideDown();
                            $('#progress-container').slideUp();
                        },
                        success: function (html) {
                            try {
                                $('#error_data_validation').slideUp();
                                
                                var returnedData = jQuery.parseJSON(html);
                                var startImport = false;
                                var error = returnedData.error || [];
                                
                                if (!error.length) {
                                    startImport = true;
                                }
                                
                                const pageSize = parseInt($('#upload_history .paginator .page-size').val()) || 5;
                                const currentPage = parseInt($('.pagination .current-page').text()) || 1;
                                
                                // Complete the progress
                                MST.updateProgressCircle(100);
                                $('#progress-text').text('Processing upload...');
                                
                                // Delay closing overlay to show completion
                                setTimeout(function() {
                                    $('#progress-container').slideUp(300);
                                    MST.updateHistory(currentPage, pageSize, false, startImport, false);
                                }, 1500);
                            } catch(e) {
                                console.error('Error parsing response:', e);
                                $('#error_data_validation').slideDown();
                                $('#progress-container').slideUp();
                                $('#import_file').val('');
                            }
                        }
                    });
                } else {
                    alert('Please complete all required fields before uploading.');
                }
            },
            updateProgressCircle: function(percentage) {
                // Circle circumference: 2 * PI * radius = 2 * 3.14159 * 20 = 125.66
                var circumference = 125.66;
                var offset = circumference - (percentage / 100) * circumference;
                $('#progress-circle').css('stroke-dashoffset', offset);
                $('#progress-percentage').text(percentage + '%');
            },
            startImport: function () {
                if ($('#edit_form').valid()) {
                    $('#upload_history tbody tr:first').find('td[class="upload_status"]').each(function() {
                        // For each td in the first tr, set background color
                        $(this).html('<img style="width: 16px;" src="<?= $block->getViewFileUrl("Lof_MarketPlace/images/loader-1.gif") ?>" alt="Loading..." style="vertical-align: middle; margin-right: 5px;" /> Uploading products...');
                    });
                    
                    //grab all form data
                    var formData = new FormData($('#edit_form')[0]);
                    $.ajax({
                        type: "POST",
                        url: "<?= $block->escapeJs($block->getUrl('*/*/processimport/')) ?>",
                        data: formData,
                        async: true,
                        cache: false,
                        contentType: false,
                        enctype: 'multipart/form-data',
                        processData: false,
                        showLoader: false,
                        beforeSend: function () {

                        },
                        error: function(e) {
                            $('#import_file').val('');
                        },
                        success: function (html) {
                            
                            $('#import_file').val('');

                            const pageSize = parseInt($('#upload_history .paginator .page-size').text()) ?? null;
                            const currentPage = parseInt($('#upload_history .pagination .current-page').text()) ?? null;

                            MST.updateHistory(currentPage, pageSize, false, false, true);
                            
                            // var $message_valid_import = $('.messages_validate_import');
                            // $message_valid_import.html('<p>Status</p>');
                            // var returnedData = jQuery.parseJSON(html);
                            // if (returnedData.error.length == 0) {
                            //     var success = returnedData.success;
                            //     for (i = 0; i < success.length; i++) {
                            //         $message_valid_import.append('<div class="message message-success success"><div>' + returnedData.success + '</div></div>');
                            //     }
                            // } else {
                            //     var notice = returnedData.notice;
                            //     for (i = 0; i < notice.length; i++) {
                            //         $message_valid_import.append('<div class="message message-error error"><div>' + returnedData.notice + '</div></div>');
                            //     }
                            // }
                        }
                    });
                }
            }
        }

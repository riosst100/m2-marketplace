            $(document).on('change', 'select', function() {
                $('#template_url').val('');

                var addedFields = 0;

                var formData = new FormData($('#edit_form')[0]);
                if ($(this).attr('id') != "categories") {
                    formData.append('code', $(this).attr('id'));
                    formData.append('option_id', $(this).val());
                }

                if (this.name == "categories") {
                    $('#sub_category_fieldset').html('');
                }
                
                $.ajax({
                    type: "POST",
                    url: "<?= $block->escapeJs($block->getUrl('*/*/bulkimportdata/')) ?>",
                    data: formData,
                    async: true,
                    cache: false,
                    contentType: false,
                    enctype: 'multipart/form-data',
                    processData: false,
                    showLoader: true,
                    beforeSend: function () { },
                    success: function (response) {
                        if (response._attribute_set) {
                            $('#_attribute_set').val(response._attribute_set);
                        }
                        
                        if (response.mapping_data) {
                            var mapping_priority = response.mapping_data.mapping_priority;
                            if (mapping_priority) {
                                $('#mapping_priority').val(mapping_priority);
                            }

                            var attribute_set_id = response.mapping_data.attribute_set_id;

                            }
                        }
                        if (response.category_details) {
                            
                            var attrCodes = [];
                            response.category_details.forEach(data => {
                                attrCodes.push(data.attribute_code);
                                if (!$('#'+data.attribute_code).length) {
                                    var element = '<div class="admin__field field required">';
                                    element += '<label for="categories" class="label admin__field-label">';
                                    element += '<span>' + data.attribute_label + '</span>';
                                    element += '</label>';
                                    element += '<div class="admin__field-control control">';
                                    element += '<div class="admin__field">';
                                    element += '<select style="width: 100%" name="' + data.attribute_code + '" id="' + data.attribute_code + '" class="admin__control-select" data-validate="{required:true}" aria-required="true">';
                                    element += '<option value="" selected hidden style="display: none;">--Please select--</option>';
                                    element += '</select>';
                                    element += '</div>';
                                    element += '</div>';
                                    element += '</div>';

                                    $('#sub_category_fieldset').append(element);

                                    $('#'+data.attribute_code).select2(
                                        {
                                            data: data.options,
                                            width: 'resolve'
                                        }
                                    );

                                    addedFields++;
                                }
                            });

                            $('#sub_category_fieldset select').each(function() {
                                // Get the name attribute of each select element
                                var selectName = $(this).attr('name');
                                // Check if the name is not in the attrCodes array
                                if (!attrCodes.includes(selectName) && selectName != "set_id") {
                                    // Remove the element
                                    $(this).closest('.admin__field.field.required').remove();
                                }
                            });

                            var fieldset = $('#sub_category_fieldset');

                            // Iterate over attrCodes and append matching elements in the correct order
                            $.each(attrCodes, function(index, attrCode) {
                                // Find the corresponding element based on its name attribute
                                var fieldElement = fieldset.find(`select[name="${attrCode}"]`).closest('.admin__field.field.required');
                                
                                // If the element exists, append it at the end of the fieldset
                                if (fieldElement.length) {
                                    fieldset.append(fieldElement);
                                }
                            });

                            var setIdField = fieldset.find('select[name="set_id"]').closest('.admin__field.field.required');
                            if (setIdField.length) {
                                fieldset.append(setIdField);
                            }
                        }

                        if (response.template_url) {
                            $('#template_url').val(response.template_url);

                            $('#download_template_btn').show();
                            $('#no_template_found').hide();

                            if (response.fields_information_html) {
                                $('#field_information_table').html(response.fields_information_html);
                            }
                        } else {
                            $('#download_template_btn').hide();
                            if (!addedFields) {

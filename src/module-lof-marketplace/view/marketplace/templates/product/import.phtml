            }

            function hideHistory() {
                $('#upload_history').slideUp();
                $('#show_upload_history').show();

                var targetRow = $('#upload_history');
                if (targetRow.length) {
                    var offset = targetRow.offset().top;
                    $('html, body').animate({
                        scrollTop: offset-200
                    }, 500); 

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$customerSession = $objectManager->get(\Magento\Customer\Model\Session::class);
$urlInterface = $objectManager->get(\Magento\Framework\UrlInterface::class);

if (!$customerSession->isLoggedIn()) {
    $customerSession->setAfterAuthUrl(str_replace('marketplace', '', $urlInterface->getCurrentUrl()));
    $customerSession->authenticate();
}

$_helper = $this->helper(\Lof\MarketPlace\Helper\Data::class);
$_sellerHelper = $this->helper(\Lof\MarketPlace\Helper\Seller::class);
$url = $this->helper(\Lof\MarketPlace\Helper\Url::class);

$imageSrc = $_helper->getMediaUrl() . 'images/user.png';

$seller = $_sellerHelper->getSellerByCustomer();
if ($seller && isset($seller['seller_id'])) {
    $dataseller = $objectManager->get(\Lof\MarketPlace\Model\Seller::class)->load($seller['seller_id']);
    if (isset($seller['thumbnail']) && $seller['thumbnail']) {
        $imageSrc = $_helper->getMediaUrl() . $seller['thumbnail'];
    }
}
?>
<div class="top_nav">
    <div class="nav_menu">
        <nav>
            <div class="nav toggle">
                <span style="padding-left: 35px;width: auto;font-size: 14px;color: black;font-weight: 400;">
                    <?php echo $block->getPageHeading() ?>
                </span>
            </div>
            <?php if ($childHtml = $block->getChildHtml()): ?>
                <div class="nav navbar-left navbar-header-block-container">
                <?= $childHtml; ?>
                </div>
            <?php endif; ?>
            <ul class="nav navbar-nav navbar-right">
                <li class="">
                    <a href="javascript:;" class="user-profile dropdown-toggle" data-toggle="dropdown"
                       aria-expanded="false">
                        <img src="<?= $block->escapeUrl($imageSrc) ?>" alt=""><?= $block->escapeHtml($seller['name']) ?>
                        <span class=" fa fa-angle-down"></span>
                    </a>
                    <ul class="dropdown-menu dropdown-usermenu pull-right">
                        <li>
                            <a target="blank" href="<?= $block->escapeUrl($dataseller->getUrl()) ?>">
                                <span><?= $block->escapeHtml(__('View My Store')) ?></span>
                            </a>
                        </li>
                        <li>
                            <a href="<?= $block->escapeUrl($this->getUrl('catalog/seller/index')) ?>">
                                <span><?= $block->escapeHtml(__('Edit Store Profile')) ?></span>
                            </a>
                        </li>
                        <li>
                            <a href="<?= $block->escapeUrl($url->getLogoutUrl()) ?>">
                                <i class="fa fa-sign-out pull-right"></i><?= $block->escapeHtml(__('Log Out')) ?>
                            </a>
                        </li>
                    </ul>
                </li>
                <li role="presentation" class="dropdown">
                    <a href="javascript:;" class="dropdown-toggle info-number" data-toggle="dropdown"
                       aria-expanded="false">
                        <i class="fa fa-bell-o"></i>
                        <?php $count = $this->getUnreadCount(); ?>
                        <span class="badge bg-green">
                            <?= $count; ?>
                        </span>
                    </a>
                    <ul id="menu1" class="dropdown-menu list-unstyled msg_list" role="menu">
                        <?php
                        $notifications = $this->getNotification(); 
                        ?>
                        <?php if ($notifications->getSize()) : ?>
                            <?php foreach ($notifications as $detail): ?>
                                <li>
                                    <?php
                                        if ($detail->getUrlPath()) {
                                            $linkToDetail = $block->getUrl($detail->getUrlPath()); 
                                        } else {
                                            $linkToDetail = '#';
                                        }
                                    ?>
                                    <a href="<?= $linkToDetail; ?>">
                                        <span>                      
                                            <span>Add Product From Database</span>                         
                                            <span class="time">
                                            <?= $_helper->nicetime($detail->getData('created_at')); ?>
                                            </span>
                                        </span>
                                        <span class="lof-message">
                                        <?= $detail->getMessage() ?>
                                        </span>
                                    </a>
                                </li>
                            <?php endforeach; ?>
                        <?php else: ?>
                            <span style="text-align: center;display: block;color: grey;padding: 10px 0; border-top: 1px solid #ccc;"> 
                                <span>No notifications.</span>                                                                           
                            </span>  
                        <?php endif; ?>
                        <a href="<?= $block->getUrl('catalog/notification/index'); ?>">
                            <span style="text-align: center;display: block;color: #000;padding: 10px 0; border-top: 1px solid #ccc;text-decoration:underline;font-weigth:700"> 
                                <span>See All Notifications</span>                                                                           
                            </span>                         
                        </a>                  
                    </ul>
                </li>
                <li class="dropdown">
                    <a href="<?= str_replace("marketplace/", "", $block->getUrl('documentation')); ?>" class="dropdown-toggle info-number" style="font-weight: 400;" target="_blank">
                        <i class="fa fa-question-circle-o" style="font-size: 17px;margin-right: 2px;vertical-align: text-bottom;"></i>
                        Seller Help Center
                    </a>
                </li>
            </ul>
        </nav>
    </div>
<?php
$unreadMsgs = count($this->getDetailUnRead()) + count($this->getDetailAdminUnRead()) + count($this->getMessageUnRead());
$messagesUrl = $this->getUrl('catalog/message');
?>
<div class="floating-messages" aria-live="polite">
    <a class="floating-messages__btn" href="<?= $block->escapeUrl($messagesUrl) ?>" title="<?= $block->escapeHtmlAttr(__('View Messages')) ?>">
        <i class="fa fa-envelope-o" aria-hidden="true"></i>
        <?php if ($unreadMsgs > 0): ?>
            <span class="floating-messages__badge" aria-label="<?= $block->escapeHtmlAttr(__('Unread messages: %1', $unreadMsgs)) ?>"><?= (int)$unreadMsgs ?></span>
        <?php endif; ?>
    </a>
</div>

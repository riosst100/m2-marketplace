                                        <?php endif; ?>


                                    <?php elseif ($code === 'tablerate'): ?>

                                        <a href="<?= $block->getUrl('lofmptablerateshipping/shipping/view') ?>"
                                           class="btn btn-activate">
                                           Configure
                                        </a>

                                    <?php elseif ($code === 'flatrate'): ?>

                                        <a href="<?= $block->getUrl('lofmpflatrateshipping/shipping/view') ?>"
                                           class="btn btn-activate">
                                           Configure
                                        </a>

                                    <?php else: ?>

                                        <?php if ($status): ?>
                                            <a href="<?= $block->getUrl('catalog/shipping/deactivate/id/' . $code) ?>"
                                                class="btn btn-deactivate">
                                                Deactivate
                                            </a>
                                        <?php else: ?>
                                            <div data-method="<?= $code ?>" 

                <?php endif; ?>

                <div id="activate-shipping-container"></div>

            </div>
        </div>
    </div>
</div>


<script type="text/javascript">
require([
    "jquery"
], function ($) {

    function activateShipping() {
        var method = $(this).data('method');

        $.ajax({
            url: '<?= $block->getUrl("catalog/shipping/activate") ?>',
            type: 'POST',
            dataType: 'json',
            data: { method: method },
            showLoader: true,
            success: function(response) {
                if (response.success) {

                    $('#cancel-shipping-' + method).show();
                    $('#activate-shipping-' + method).hide();

                    $('#activate-shipping-container').html(response.html).slideDown();

                    $('html, body').animate({
                        scrollTop: $('#activate-shipping-container').offset().top
                    }, 600);
                }
            }
        });
    }

    $('.activate-shipping').on('click', activateShipping);

    $('.cancel-shipping').on('click', function(){
        var method = $(this).data('method');
        $('#cancel-shipping-' + method).hide();
        $('#activate-shipping-container').slideUp();
        $('#activate-shipping-' + method).show();
    });

});
</script>



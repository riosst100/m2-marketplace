$helper = $this->helper(\Lof\MarketPlace\Helper\Data::class);
$formActionUrl = $this->getUrl('catalog/messageadmin/save');
$currPageUrl = $helper->getCurrentUrls();
$this->isRead();

?>
<div class="row">
    <div class="col-md-12 col-sm-12 col-xs-12">
        <div class="x_panel">
            <div class="x_title">
                <h2><?= $block->escapeHtml($this->getMessage()->getSubject()) ?></h2>
                <div class="clearfix"></div>
            </div>
            <div class="x_content">
                <p><?= $block->escapeHtml($this->getMessage()->getDescription()) ?></p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-sm-12 col-xs-12 admin-msg-left">
        <div class="x_panel">
            <div class="x_title">
                <h2><?= $block->escapeHtml(__('Post a Reply')) ?></h2>
                <div class="clearfix"></div>
            </div>
            <div class="x_content">
                <form id="form-message" data-parsley-validate="" action="<?= $block->escapeUrl($formActionUrl) ?>"
                      class="form-horizontal form-label-left seller-message-reply" method="post"
                      data-hasrequired="<?= $block->escapeHtmlAttr(__('* Required Fields')) ?>"
                      data-mage-init='{"validation":{}}'>
                    <div class="form-group">
                        <label class="control-label col-md-2 col-sm-2 col-xs-2" for="content">
                            <?= $block->escapeHtml(__('Message')) ?>
                            <span class="required">*</span>
                        </label>
                        <div class="col-md-10 col-sm-10 col-xs-10">
                            <textarea name="content" rows="10" id="content" required="required"
                                      class="form-control col-md-7 col-xs-12"> </textarea>
                        </div>
                    </div>
                    <div class="ln_solid"></div>
                    <div class="form-group">
                        <div class="col-md-12 col-sm-12 col-xs-12">
                            <input type="hidden" name="sender_id"
                                   value="<?= $block->escapeHtmlAttr($this->getSeller()->getSellerId()) ?>"/>
                            <input type="hidden" name="seller_send" value="1"/>
                            <input type="hidden" name="sender_name"
                                   value="<?= $block->escapeHtmlAttr($this->getSeller()->getName()) ?>"/>
                            <input type="hidden" name="sender_email"
                                   value="<?= $block->escapeHtmlAttr($this->getSeller()->getEmail()) ?>"/>
                            <input type="hidden" name="message_id"
                                   value="<?= $block->escapeHtmlAttr($this->getMessage()->getMessageId()) ?>"/>
                            <input type="hidden" name="currUrl" id="currUrl"
                                   value="<?= $block->escapeHtmlAttr($currPageUrl) ?>"/>                            
                            </button>
                            <button type="submit" class="btn btn-success">
                                <?= $block->escapeHtml(__('Send Message')) ?>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-sm-12 col-xs-12 admin-msg-right">
        <div class="x_panel">
            <div class="x_title">
                <h2><?= $block->escapeHtml(__('Message History')) ?></h2>
                <div class="clearfix"></div>
            </div>
            <div class="x_content">
                <ul class="chat-messages-history" id="admin-message-list">
                    <script>
                        (function(){
                            var list = document.getElementById('admin-message-list');
                            if (list) { list.scrollTop = list.scrollHeight; }
                        })();
                    </script>
                    <?php foreach ($this->getDetail() as $key => $detail):
                        $isSelf = ($detail->getSenderId() == $this->getSeller()->getSellerId());
                        $timeText = $helper->formatDateTime($detail->getCreatedAt(), \IntlDateFormatter::SHORT, true);
                    ?>
                        <li class="chat-row <?= $isSelf ? 'self' : 'other' ?>">
                            <div class="chat-bubble <?= $isSelf ? 'self' : 'other' ?>">
                                <?php if ($isSelf): ?>
                                    <div class="chat-header self">
                                        <span class="chat-time"><?= $block->escapeHtml($timeText) ?></span>
                                    </div>
                                    <div class="chat-content"><?= $block->escapeHtml($detail->getContent()) ?></div>
                                <?php else: ?>
                                    <div class="chat-header">
                                        <span class="chat-sender"><?= $block->escapeHtml($detail->getSenderName()) ?></span>
                                        <span class="chat-time"><?= $block->escapeHtml($timeText) ?></span>
                                    </div>
                                    <div class="chat-content"><?= $block->escapeHtml($detail->getContent()) ?></div>
                                <?php endif; ?>
                            </div>
                        </li>
                    <?php endforeach; ?>
                </ul>
            </div>
        </div>
    </div>
</div>

<?php
/** @var $block \Lof\MarketPlace\Block\Seller\Notification */
$notifications = $block->getNotifications();
?>
<div class="row">
    <div class="col-md-12" style="margin-top:10px;">
        <div class="panel panel-default">
            <div class="panel-body">
                <h2>Notifications</h2>
                <p>This page shows notifications for new orders, messages, and other important updates. Click a notification to open the related page.</p>
                <div id="upload_history" style="display: block;">
                    <table class="data-grid">
                        <thead>
                            <tr>
                                <th class="data-grid-th"><?= __('Title') ?></th>
                                <th class="data-grid-th"><?= __('Message') ?></th>
                                <th class="data-grid-th"><?= __('Date Time') ?></th>
                            </tr>
                        </thead>
                        <tbody id="upload_history_content">
                            <?php
                            $currentPage = $this->getRequest()->getParam('page') ?? 1;
                            $pageSize = $this->getRequest()->getParam('size') ?? 5;
                            $totalCount = count($notifications);
                            $totalPages = ceil($totalCount / $pageSize);
                            // $importHistory = $block->getImportHistory($currentPage, $pageSize);
                            ?>
                            <?php if ($notifications->getSize()): ?>
                                <?php foreach ($notifications as $notif): ?>
                                    <?php
                                        $linkToDetail = $notif->getUrlPath()
                                            ? $block->getUrl($notif->getUrlPath())
                                            : '#';
                                    ?>
                                    <tr onclick="window.location='<?= $linkToDetail ?>';"
                                        style="cursor: pointer;"
                                        class="<?= !$notif->getIsRead() ? 'unread' : '' ?>">
                                         <td>
                                            <span class="lof-message">
                                                <?= $notif->getTitle() ?>
                                                </span></td>
                                        <td>
                                            <span class="lof-message">
                                                <?= $notif->getMessage() ?>
                                                </span></td>
                                        <td><?= $block->escapeHtml($notif->getCreatedAt()) ?></td>
                                    </tr>
                                <?php endforeach; ?>
                            <?php else: ?>
                                <tr>
                                    <td colspan="8">
                                        <div class="empty-state">
                                            <p><?= __('No notifications.') ?></p>
                                        </div>
                                    </td>
                                </tr>
                            <?php endif; ?>
                        </tbody>
                    </table>
                    <div class="paginator">
                        <span class="total"><?= __('Total %1', $totalCount) ?></span>
                        <select class="page-size" onchange="MST.changePageSize(this.value)">
                            <option value="5" <?= $pageSize == 5 ? 'selected' : '' ?>>5</option>
                            <option value="10" <?= $pageSize == 10 ? 'selected' : '' ?>>10</option>
                            <option value="20" <?= $pageSize == 20 ? 'selected' : '' ?>>20</option>
                            <option value="50" <?= $pageSize == 50 ? 'selected' : '' ?>>50</option>
                        </select>
                        <div class="pagination">
                            <button class="prev-page" type="button" onclick="MST.changePage(<?= $currentPage - 1 ?>)" <?= $currentPage == 1 ? 'disabled' : '' ?>><span class="fa fa-chevron-left" style="margin-right: 5px;"></span><?= __('Previous') ?></button>
                            <span class="current-page"><?= $currentPage ?></span>
                            <button class="next-page" type="button" onclick="MST.changePage(<?= $currentPage + 1 ?>)" <?= $currentPage == $totalPages ? 'disabled' : '' ?>><?= __('Next') ?><span class="fa fa-chevron-right" style="margin-left: 5px;"></span></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

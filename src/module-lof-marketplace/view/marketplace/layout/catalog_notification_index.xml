<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="vendor-1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="seller_store_switcher"/>
    <body>
        <referenceContainer name="content">
            <block class="Lof\MarketPlace\Block\Seller\Notification"
                   name="seller.notifications"
                   template="Lof_MarketPlace::seller/notification/list.phtml">
                <!-- Pagination Block -->
                <block class="Magento\Theme\Block\Html\Pager"
                    name="notification.pager"
                    template="Magento_Theme::html/pager.phtml">
                    <arguments>
                        <argument name="show_per_page" xsi:type="boolean">true</argument>
                        <argument name="limit" xsi:type="number">10</argument>
                        <argument name="limit_var_name" xsi:type="string">limit</argument>
                        <argument name="page_var_name" xsi:type="string">p</argument>
                    </arguments>
                </block>
            </block>
        </referenceContainer>
    </body>
</page>

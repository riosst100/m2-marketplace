<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
	xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
	<body>
		<referenceContainer name="content">
			<container name="seller.login.container" label="Seller Forgot Password Container"
				htmlTag="div" htmlClass="login-container">
				<block class="Lof\MarketPlace\Block\Seller\ForgotPassword" name="marketplace_seller_forgotpassword"
					template="Lof_MarketPlace::seller/forgotpassword.phtml">
					<container name="form.additional.info" as="form_additional_info" />
				</block>
				<!-- <block class="Magento\Customer\Block\Form\Login\Info" name="seller.new"
					template="Lof_MarketPlace::seller/newcustomer.phtml" /> -->
			</container>
			<block class="Magento\Cookie\Block\RequireCookie" name="require-cookife"
				template="Magento_Cookie::require_cookie.phtml">
				<arguments>
					<argument name="triggers" xsi:type="array">
						<item name="submitButton" xsi:type="string">.action.submit</item>
					</argument>
				</arguments>
			</block>
		</referenceContainer>
	</body>
</page>

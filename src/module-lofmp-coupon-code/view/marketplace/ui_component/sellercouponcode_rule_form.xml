<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">sellercouponcode_rule_form.sellercouponcode_rule_data_source</item>
            <item name="deps" xsi:type="string">sellercouponcode_rule_form.sellercouponcode_rule_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">New Rule</item>
        <item name="config" xsi:type="array">
            <item name="dataScope" xsi:type="string">data</item>
            <item name="namespace" xsi:type="string">sellercouponcode_rule_form</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="Lofmp\CouponCode\Block\MarketPlace\Form\Rule\SaveButton"/>
            <button name="reset" class="Lofmp\CouponCode\Block\MarketPlace\Form\Rule\ResetButton"/>
            <button name="back"
                    class="Lofmp\CouponCode\Block\MarketPlace\Form\Rule\BackButton"/>
            <button name="save_and_continue"
                    class="Lofmp\CouponCode\Block\MarketPlace\Form\Rule\SaveContinueButton"/>
        
        </buttons>
        <namespace>sellercouponcode_rule_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>sellercouponcode_rule_form.sellercouponcode_rule_data_source</dep>
        </deps>
    </settings>
    <dataSource name="sellercouponcode_rule_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Lofmp\CouponCode\Model\Rule\DataProvider</argument>
            <argument name="name" xsi:type="string">sellercouponcode_rule_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">coupon_rule_id</argument>
            <argument name="requestFieldName" xsi:type="string">coupon_rule_id</argument>
        </argument>
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="lofmpcouponcode/rule/saveRule"/>
        </settings>
    </dataSource>
    <fieldset name="rule_information_field" sortOrder="10">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="collapsible" xsi:type="boolean">false</item>
                <item name="label" xsi:type="string" translate="true">Rule Information</item>
                <item name="sortOrder" xsi:type="number">10</item>
            </item>
        </argument>
        <field name="name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Rule Name</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">name</item>
                </item>
            </argument>
        </field>
        <field name="rule_key">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Rule Identifier Key</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">false</item>
                    </item>
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">rule_key</item>
                </item>
            </argument>
        </field>
        <field name="description">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Description</item>
                    <item name="formElement" xsi:type="string">textarea</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">description</item>
                    <item name="additionalInfo" xsi:type="string" translate="true"><![CDATA[<strong>Description for Rule</strong>]]></item>
                </item>
            </argument>
        </field>
        <field name="customer_group_ids">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Lofmp\CouponCode\Model\Config\Source\CustomerGroups</item>
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Customer Groups</item>
                    <item name="formElement" xsi:type="string">multiselect</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="dataScope" xsi:type="string">customer_group_ids</item>
                </item>
            </argument>
        </field>
        <field name="from_date">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">From Date</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">date</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">from_date</item>
                    <item name="notice"  xsi:type="string" translate="true">You can set a future date to schedule the rule. The rule will not be available until this date.</item>
                </item>
            </argument>
        </field>
        <field name="to_date">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">To Date</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">date</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">to_date</item>
                    <item name="notice"  xsi:type="string" translate="true">You can set a future date to schedule the rule. The rule will not be available until this date.</item>
                </item>
            </argument>
        </field>
        <!-- <field name="uses_per_customer">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Uses Per Customer</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">uses_per_customer</item>
                </item>
            </argument>
        </field> -->
        <field name="uses_per_coupon">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Uses Per Coupon</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">uses_per_coupon</item>
                    <item name="notice"  xsi:type="string" translate="true">Input number to limit usage per coupon. Input 0 or empty for unlimited.</item>
                </item>
            </argument>
        </field>
        <field name="sort_order">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Priority</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="dataScope" xsi:type="string">sort_order</item>
                </item>
            </argument>
        </field>
        <field name="is_active">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">boolean</item>
                    <item name="label" xsi:type="string" translate="true">Enable Rule</item>
                    <item name="formElement" xsi:type="string">checkbox</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">is_active</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="true" xsi:type="number">1</item>
                        <item name="false" xsi:type="number">0</item>
                    </item>
                    <item name="default" xsi:type="number">1</item>
                </item>
            </argument>
        </field>
        <field name="limit_generated">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Limit Number Coupons Was Generated Per Email</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">limit_generated</item>
                    <item name="notice"  xsi:type="string" translate="true">Limit number coupons can generated for a email address.</item>
                </item>
            </argument>
        </field>
        <field name="is_check_email">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">boolean</item>
                    <item name="label" xsi:type="string" translate="true">Enable check email address when use coupon code</item>
                    <item name="formElement" xsi:type="string">checkbox</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">is_check_email</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="true" xsi:type="number">1</item>
                        <item name="false" xsi:type="number">0</item>
                    </item>
                    <item name="default" xsi:type="number">1</item>
                    <item name="notice"  xsi:type="string" translate="true">Enable/disable check exactly email address when apply coupon code on shopping cart and checkout page. If not equal, the coupon code can not apply.</item>
                </item>
            </argument>
        </field>
    </fieldset>
    <fieldset name="coupon_usage_field" sortOrder="20">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="collapsible" xsi:type="boolean">true</item>
                <item name="label" xsi:type="string" translate="true">Coupon Usage</item>
                <item name="sortOrder" xsi:type="number">20</item>
            </item>
        </argument>
        <field name="coupons_length">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Code Length</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">coupons_length</item>
                    <item name="notice"  xsi:type="string" translate="true">Excluding prefix, suffix and separators.</item>
                </item>
            </argument>
        </field>
        <field name="coupons_format">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Lofmp\CouponCode\Model\Config\Source\CouponsFormat</item>
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Code Format</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">coupons_format</item>
                </item>
            </argument>
        </field>
        <field name="coupons_prefix">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Code Prefix</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">coupons_prefix</item>
                </item>
            </argument>
        </field>
        <field name="coupons_suffix">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Code Suffix</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">coupons_suffix</item>
                </item>
            </argument>
        </field>
        <field name="coupons_dash">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Dash Every X Characters</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">rule</item>
                    <item name="dataScope" xsi:type="string">coupons_dash</item>
                    <item name="notice"  xsi:type="string" translate="true">If empty no separation.</item>
                </item>
            </argument>
        </field>
    </fieldset>
    <fieldset name="conditions_section" sortOrder="25">
        <settings>
            <collapsible>true</collapsible>
            <label translate="true">Conditions</label>
        </settings>

        <!-- Applicable Category -->
        <field name="category_condition" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="array">
                    <item name="0" xsi:type="array">
                        <item name="label" xsi:type="string">All Categories</item>
                        <item name="value" xsi:type="string">all</item>
                    </item>
                    <item name="1" xsi:type="array">
                        <item name="label" xsi:type="string">Specific Categories</item>
                        <item name="value" xsi:type="string">specific</item>
                    </item>
                </item>
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Applicable Category</item>
                    <item name="dataScope" xsi:type="string">category_condition</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">select</item>
                </item>
            </argument>
        </field>

        <!-- Select Category (visible only when specific category chosen) -->
        <field name="select_category" formElement="select">
            <argument name="data" xsi:type="array">
                <!-- <item name="options" xsi:type="object">Lofmp\CouponCode\Model\Config\Source\CategoryOptions</item> -->
                <item name="options" xsi:type="array">
                    <item name="select" xsi:type="array">
                        <item name="label" xsi:type="string">All Categories</item>
                        <item name="value" xsi:type="string"></item>
                    </item>

                    <item name="actiontoys" xsi:type="array">
                        <item name="label" xsi:type="string">Action Toys</item>
                        <item name="value" xsi:type="string">actiontoys</item>
                    </item>

                    <item name="actiontoysmodelkits" xsi:type="array">
                        <item name="label" xsi:type="string">Action Toys Model Kits</item>
                        <item name="value" xsi:type="string">actiontoysmodelkits</item>
                    </item>

                    <item name="animetoys" xsi:type="array">
                        <item name="label" xsi:type="string">Anime Toys</item>
                        <item name="value" xsi:type="string">animetoys</item>
                    </item>

                    <item name="animemodelkits" xsi:type="array">
                        <item name="label" xsi:type="string">Anime Model Kits</item>
                        <item name="value" xsi:type="string">animemodelkits</item>
                    </item>

                    <item name="gundam" xsi:type="array">
                        <item name="label" xsi:type="string">Gundam</item>
                        <item name="value" xsi:type="string">gundam</item>
                    </item>

                    <item name="fungoods" xsi:type="array">
                        <item name="label" xsi:type="string">Fun Goods</item>
                        <item name="value" xsi:type="string">fungoods</item>
                    </item>

                    <item name="fashiondolls" xsi:type="array">
                        <item name="label" xsi:type="string">Fashion Dolls</item>
                        <item name="value" xsi:type="string">fashiondolls</item>
                    </item>

                    <item name="dollsaccessories" xsi:type="array">
                        <item name="label" xsi:type="string">Doll Accessories</item>
                        <item name="value" xsi:type="string">dollsaccessories</item>
                    </item>

                    <item name="cardgame" xsi:type="array">
                        <item name="label" xsi:type="string">Collectible Card Games</item>
                        <item name="value" xsi:type="string">cardgame</item>
                    </item>

                    <item name="livingcardgames" xsi:type="array">
                        <item name="label" xsi:type="string">Living Card Games</item>
                        <item name="value" xsi:type="string">livingcardgames</item>
                    </item>

                    <item name="miniaturegames" xsi:type="array">
                        <item name="label" xsi:type="string">Miniature Games</item>
                        <item name="value" xsi:type="string">miniaturegames</item>
                    </item>

                    <item name="gamesworkshop" xsi:type="array">
                        <item name="label" xsi:type="string">Games Workshop</item>
                        <item name="value" xsi:type="string">gamesworkshop</item>
                    </item>

                    <item name="sportcards" xsi:type="array">
                        <item name="label" xsi:type="string">Sport Cards</item>
                        <item name="value" xsi:type="string">sportcards</item>
                    </item>

                    <item name="nonsportcards" xsi:type="array">
                        <item name="label" xsi:type="string">Non Sports Cards</item>
                        <item name="value" xsi:type="string">nonsportcards</item>
                    </item>

                    <item name="bricks" xsi:type="array">
                        <item name="label" xsi:type="string">Bricks</item>
                        <item name="value" xsi:type="string">bricks</item>
                    </item>

                    <item name="diecastvehicles" xsi:type="array">
                        <item name="label" xsi:type="string">Diecast Vehicles</item>
                        <item name="value" xsi:type="string">diecastvehicles</item>
                    </item>

                    <item name="diecastaircrafts" xsi:type="array">
                        <item name="label" xsi:type="string">Diecast Aircrafts</item>
                        <item name="value" xsi:type="string">diecastaircrafts</item>
                    </item>

                    <item name="diecastmilitary" xsi:type="array">
                        <item name="label" xsi:type="string">Diecast Military</item>
                        <item name="value" xsi:type="string">diecastmilitary</item>
                    </item>

                    <item name="diecastaccessories" xsi:type="array">
                        <item name="label" xsi:type="string">Diecast Accessories</item>
                        <item name="value" xsi:type="string">diecastaccessories</item>
                    </item>

                    <item name="modelkitsvehicles" xsi:type="array">
                        <item name="label" xsi:type="string">Model Kits Vehicles</item>
                        <item name="value" xsi:type="string">modelkitsvehicles</item>
                    </item>

                    <item name="modelkitsaircrafts" xsi:type="array">
                        <item name="label" xsi:type="string">Model Kits Aircrafts</item>
                        <item name="value" xsi:type="string">modelkitsaircrafts</item>
                    </item>

                    <item name="modelkitsmilitary" xsi:type="array">
                        <item name="label" xsi:type="string">Model Kits Military</item>
                        <item name="value" xsi:type="string">modelkitsmilitary</item>
                    </item>

                    <item name="railway" xsi:type="array">
                        <item name="label" xsi:type="string">Trains</item>
                        <item name="value" xsi:type="string">railway</item>
                    </item>

                    <item name="railwayaccessories" xsi:type="array">
                        <item name="label" xsi:type="string">Trains Accessories</item>
                        <item name="value" xsi:type="string">railwayaccessories</item>
                    </item>

                    <item name="hobbysupplies" xsi:type="array">
                        <item name="label" xsi:type="string">Hobby Supplies</item>
                        <item name="value" xsi:type="string">hobbysupplies</item>
                    </item>

                    <item name="hobbysuppliescardsgames" xsi:type="array">
                        <item name="label" xsi:type="string">Cards &amp; Games</item>
                        <item name="value" xsi:type="string">hobbysuppliescardsgames</item>
                    </item>
                </item>
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Select Category</item>
                    <item name="dataScope" xsi:type="string">select_category</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="visible" xsi:type="boolean">true</item>
                    <item name="disabled" xsi:type="boolean">true</item>
                    <item name="imports" xsi:type="array">
                        <item name="visible" xsi:type="string">${ $.provider }:data.category_condition == 'specific'</item>
                    </item>
                </item>
            </argument>
        </field>

        <!-- Applicable Products -->
        <field name="products_condition" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="array">
                    <item name="0" xsi:type="array">
                        <item name="label" xsi:type="string">All Products</item>
                        <item name="value" xsi:type="string">all</item>
                    </item>
                    <item name="1" xsi:type="array">
                        <item name="label" xsi:type="string">Specific Products</item>
                        <item name="value" xsi:type="string">specific</item>
                    </item>
                </item>
                <!-- imports moved under config to align with Magento UI patterns -->
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Applicable Products</item>
                    <item name="dataScope" xsi:type="string">products_condition</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="disabled" xsi:type="boolean">true</item>
                    <item name="imports" xsi:type="array">
                        <item name="visible" xsi:type="string">${ $.provider }:data.category_condition == 'specific'</item>
                        <item name="disabled" xsi:type="string">${ $.provider }:data.category_condition != 'specific'</item>
                    </item>
                </item>
            </argument>
        </field>
        <!-- Add Products Button -->        
        <field name="add_products_button" formElement="button">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Add Products</item>
                    <item name="formElement" xsi:type="string">button</item>
                    <item name="componentType" xsi:type="string">button</item>
                    <item name="actions" xsi:type="array">
                        <item name="0" xsi:type="array">
                            <item name="targetName" xsi:type="string">add_products_modal</item>

<?xml version="1.0"?>
<modal xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd"
       name="add_products_modal">
    <argument name="data" xsi:type="array">
        <item name="config" xsi:type="array">
            <item name="component" xsi:type="string">Magento_Ui/js/modal/modal-component</item>
            <item name="componentType" xsi:type="string">modal</item>
            <item name="title" xsi:type="string" translate="true">Select Products</item>
            <item name="options" xsi:type="array">
                <item name="buttons" xsi:type="array">
                    <item name="0" xsi:type="array">
                        <item name="text" xsi:type="string" translate="true">Close</item>
                        <item name="class" xsi:type="string">action-secondary</item>
                        <item name="actions" xsi:type="array">
                            <item name="0" xsi:type="string">closeModal</item>
                        </item>
                    </item>
                </item>
            </item>
        </item>
    </argument>

    <!-- ✅ Place your component directly here -->
    <uiComponent name="vendor_catalog_cardgame_singles_listing"/>
</modal>

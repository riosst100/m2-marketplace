<script type="text/javascript">
require(['jquery', 'mage/url'], function ($, urlBuilder) {
    'use strict';

    function patchRuleChoosers() {
        $('.rule-chooser:not([data-chooser-patched])').each(function () {
            var $el = $(this);
            var originalUrl = $el.attr('url') || '';

            if (!originalUrl) {
                $el.attr('data-chooser-patched', '1');
                return;
            }

            // Detect "chooser" part
            var idx = originalUrl.indexOf('chooser');
            if (idx === -1) {
                $el.attr('data-chooser-patched', '1');
                return;
            }

            // Extract the suffix after "chooser"
            var suffix = originalUrl.substring(idx + 'chooser'.length);

            // Ensure base URL starts from root (store-aware)
            var baseUrl = window.BASE_URL || urlBuilder.build('/');
            if (baseUrl.slice(-1) !== '/') baseUrl += '/';

            var newUrl = baseUrl + 'marketplace/lofmpcouponcode/rule/chooser' + suffix;

            console.log('[RuleChooserPatch] Replacing chooser URL:', originalUrl, '→', newUrl);

            $el.attr('url', newUrl);
            $el.attr('data-chooser-patched', '1');
        });
    }

    // Run once DOM ready
    $(function () {
        patchRuleChoosers();

        // Observe dynamically added chooser divs (when conditions are added)
        var observer = new MutationObserver(function () {
            patchRuleChoosers();
        });

        observer.observe(document.body, { childList: true, subtree: true });
    });
});
</script>

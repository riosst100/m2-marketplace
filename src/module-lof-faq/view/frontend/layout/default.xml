<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
	<head>
		<css src="Lof_All::lib/fancybox/jquery.fancybox.css"/>
		<css src="Lof_All::lib/bootstrap/css/bootstrap-tiny.css"/>
		<css src="Lof_Faq::css/styles.css" />
        <css src="Lof_Faq::css/font-awesome.min.css" />
        <css src="Lof_Faq::css/animate.css" />
	</head>
	<body>
		<referenceContainer name="footer" remove="true"/>
		<referenceBlock name="top.search" remove="true"/>
		<referenceBlock name="minicart" remove="true"/>
		<referenceBlock name="faq.tag.list" remove="true"/>
		<referenceContainer name="navigation.sections" remove="true"/>
		<referenceContainer name="header.panel.wrapper" remove="true"/>
		<referenceBlock name="sale.reorder.sidebar" remove="true"/>
		<referenceBlock name="wishlist_sidebar" remove="true"/>
		<referenceBlock name="catalog.compare.sidebar" remove="true"/>
		<referenceBlock name="header.links">
			<block class="Lof\Faq\Block\Toplinks" name="loffaq-toplinks">
				<arguments>
					<argument name="label" xsi:type="string" translate="true">LOF FAQ</argument>
				</arguments>
			</block>
		</referenceBlock>
	</body>
</page>
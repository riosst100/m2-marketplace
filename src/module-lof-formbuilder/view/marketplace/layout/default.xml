<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
	<head>
		<css src="Lof_All::lib/fancybox/jquery.fancybox.css" />
		<css src="Lof_Formbuilder::css/bootstrap-tiny.css" />
		<css src="Lof_Formbuilder::js/raty/jquery.raty.css" />
		<css src="Lof_Formbuilder::css/font-awesome.min.css" />
		<css src="Lof_Formbuilder::css/jquery.dm-uploader.min.css" />
		<css src="Lof_Formbuilder::css/styles.css" />
	</head>
	<body>
		<referenceBlock name="header.links">
			<block class="Lof\Formbuilder\Block\Toplinks" ifconfig="lofformbuilder/general_settings/enable" name="lofformbuilder-toplinks">
				<arguments>
					<argument name="label" xsi:type="string" translate="true">LOF Formbuilder</argument>
				</arguments>
			</block>
		</referenceBlock>
		<referenceContainer name="before.body.end">
			<!-- <block class="Magento\Framework\View\Element\Template" ifconfig="lofformbuilder/general_settings/enable" name="formbuilder.js" after="-" template="Lof_Formbuilder::js.phtml" /> -->
		</referenceContainer>
	</body>
</page>

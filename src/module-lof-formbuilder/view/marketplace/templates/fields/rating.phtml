use Lof\Formbuilder\Helper\Data;
use Lof\Formbuilder\Helper\Fields;

$helper           = $this->helper(Fields::class);
$dataHelper       = $this->helper(Data::class);
$form             = $block->getForm();
$formData        = $this->getData('form_data');
$field            = $this->getData('field_data');
$fieldType       = $field['field_type'];
$label            = $block->filterMessage($field['label']);
$options          = $field['field_options'];
$required         = $field['required'];
$cid              = $dataHelper->getFieldId($field);
$fieldName       = $helper->getFieldPrefix() . $cid . $form->getId();
$fieldId          = $fieldName.uniqid();
$availableFields = $helper->getAvailableFields();
$fieldValidate   = $availableFields[$fieldType] ?? '';
$validates        = $fieldValidate;
$fieldHelp       = isset($options['description']) ? $block->filterMessage($options['description']) : '';
$inlineCss        = $field['inline_css'] ?? '';
$cssClass   = isset($field['css_class']) ? ($block->escapeHtmlAttr($field['css_class']).' ') : '';
if ($fieldValidate && is_array($fieldValidate)) {
    $validates = implode(" ", $fieldValidate);
}
$limit = isset($field['limit']) ? (int)$field['limit'] : 5;
$default = isset($field['default']) ? (float)$field['default'] : 0;
?>
<div class="subtemplate-wrapper <?= $cssClass; ?>" style="<?= $inlineCss ?>">
    <label for="<?= $fieldId; ?>" class="<?= (1 == $required) ? 'required' : ''; ?>"><?= __($label); ?><?= (1 == $required) ? '<em>*</em>' : '';?></label>
    <div class="input-box">
        <input name="<?= $fieldName; ?>" id="<?= $fieldId; ?>" title="<?= $label; ?>" value="<?= ($formData && isset($formData[$fieldName])) ? $formData[$fieldName] : ''; ?>" class="input-text <?= (1 == $required) ? 'required-entry' : ''; ?>" type="hidden"/>
        <input name="<?= $fieldName."_limit"; ?>" id="<?= $fieldId."_limit"; ?>" title="<?= $label; ?>" value="<?= $limit; ?>" class="input-text" type="hidden"/>
        <div id="<?= $fieldId."_rating"; ?>" class="ves-rating-play"></div>
        <script type="text/javascript">
            require(['jquery', 'Lof_Formbuilder/js/raty/raty'], function(){
                jQuery('#<?= $fieldId."_rating"; ?>').raty({
                    path: '<?= $block->escapeUrl($dataHelper->getMediaUrl()."lof/formbuilder/rating/"); ?>',
                    score: <?= $default; ?>,
                    number: <?= $limit; ?>,
                    targetScore: '#<?= $fieldId; ?>',
                    click: function(score, evt) {
                        jQuery('#<?= $fieldId; ?>').val(score);
                        return false;
                    }
                });
            });
        </script>
        <?php if ($fieldHelp) : ?>
        <span class="help-block"><?= $fieldHelp; ?></span>
        <?php endif; ?>
    </div>
</div>

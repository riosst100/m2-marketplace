use Lof\Formbuilder\Helper\Data;
use Lof\Formbuilder\Helper\Fields;

$helper         = $this->helper(Fields::class);
$dataHelper      = $this->helper(Data::class);
$form           = $block->getForm();
$formData      = $this->getData('form_data');
$field          = $this->getData('field_data');
$fieldType     = $field['field_type'];
$label          = $block->filterMessage($field['label']);
$options        = $field['field_options'];
$required       = $field['required'];
$cid              = $dataHelper->getFieldId($field);
$frameWorkCss = '';
if (isset($field['frame_work_css'])) {
    $frameWorkCss      = $field['frame_work_css'];
}
$fieldName        = $helper->getFieldPrefix() . $cid . $form->getId();
$fieldId          = $fieldName . uniqid();
$availableFields = $helper->getAvailableFields();
$html             = '';
$fieldValidate   = $availableFields[$fieldType] ?? '';
$validates        = $fieldValidate;
$fieldHelp       = isset($options['description']) ? $block->filterMessage($options['description']) : '';
$inlineCss        = $field['inline_css'] ?? '';
$cssClass   = isset($field['css_class']) ? ($block->escapeHtmlAttr($field['css_class']).' ') : '';
$colorLabel       = isset($options['color_label']) ? 'color:' . $options['color_label'] . ';' : '';
$colorText       = isset($options['color_text']) ? 'color:' . $options['color_text'] . ';' : '';
$colorDescription = isset($options['color_description']) ? 'color:' . $options['color_description'] . ';' : '';
$backgroundColor = isset($options['background_color']) ? 'background-color:' . $options['background_color'] . ';' : '';

$borderWidth         = isset($options['border_width']) ? 'border-width:' . (int)$options['border_width'] . 'px;' : '';
$borderRadius        = isset($options['border_radius']) ? 'border-radius:' . (int)$options['border_radius'] . 'px;' : '';
$borderColor         = isset($options['border_color']) ? 'border-color:' . $options['border_color'] . ';' : '';
$borderStyle         = isset($options['border_style']) ? 'border-style:' . $options['border_style'] . ';' : '';
$fontSize            = isset($options['font_size']) ? 'font-size:' . (int)$options['font_size'] . 'px;' : '';
$fontStyle           = isset($options['font_style']) ? 'font-style:' . $options['font_style'] . ';' : '';
$fontWeight          = isset($options['font_weight']) ? 'font-weight:' . $options['font_weight'] . ';' : '';
$dateValidationYear      = isset($field['date_validation_year']) ? @trim($field['date_validation_year']) : '';
$dateValidationTo      = isset($field['date_validation_to']) ? @trim($field['date_validation_to']) : '';

$fontSize           = isset($options['font_size']) ? 'font-size:' . (int)$options['font_size'] . 'px;' : '';
$fontStyle       = isset($options['font_style']) ? 'font-style:' . $options['font_style'] . ';' : '';
$fontWeight      = isset($options['font_weight']) ? 'font-weight:' . $options['font_weight'] . ';' : '';

$icon              = $options['icon'] ?? '';
$iconColor          = isset($options['icon_color']) ? $options['icon_color'] : '';

if ($fieldValidate && is_array($fieldValidate)) {
    $validates = implode(" ", $fieldValidate);
}
$dateFormat = $dataHelper->getConfig("general_settings/dateformat");
if ($frameWorkCss == 'foundation') {
    $medium = 'columns medium-';
} else {
    $medium = 'col-sm-';
}

$maxDate = "";
if ($dateValidationYear) {
    $dateValidationYear = (int)$dateValidationYear;
    $currentYear =  date("Y");
    if ($dateValidationYear > 0 && $dateValidationYear < 200) {
        $dateValidationTo = date("Y") - $dateValidationYear;
    }
}
if ($dateValidationTo) {
    if (!str_contains($dateValidationTo, "/")) {
        $month = date('m');
        $day = date('d');
        $maxDate = (int)$month."/".(int)$day."/".(int)$dateValidationTo;
    } else {
        $maxArr = explode("/", $dateValidationTo);
        $maxDate = (count($maxArr) == 3) ? $dateValidationTo : "";
    }
}
$maxDateValue = $maxDate;
$verifyDateRange = "";
$maxDateClass = "validate-date-range date-range-".$fieldId."-to";

if (!empty($maxDate)) {
    $verifyDateRange = "validate-date validate-date-range date-range-".$fieldId."-".$fieldId."to";
} else {
    $maxDateValue = "01/01/2100";
}
?>
<div class="subtemplate-wrapper <?= $cssClass; ?>" style="<?= $inlineCss ?>">
    <label for="<?= $fieldId; ?>" style="<?= $fontSize . $fontStyle . $fontWeight . $colorLabel; ?>" class="<?= (1 == $required) ? 'required' : ''; ?>"><?= $label; ?><?= (1 == $required) ? '<em>*</em>' : '';?></label>
    <div class="row">
        <div class="input-box <?= isset($field['fieldcol']) ? $medium . $field['fieldcol'] : 'col-sm-12'; ?>">
            <div class="subtemplate-inner">
                <input type="hidden" class="<?= $maxDateClass; ?>" value="<?= $maxDateValue; ?>"/>
                <input autocomplete="off" style="<?= $colorText . $backgroundColor . $borderWidth . $borderRadius . $borderColor . $borderStyle; ?>" name="<?= $fieldName; ?>" id="<?= $fieldId; ?>" title="<?= $label; ?>" value="<?= ($formData && isset($formData[$fieldName])) ? $formData[$fieldName] : ''; ?>" class="input-text <?= (1 == $required) ? 'required-entry' : ''?> <?= $verifyDateRange; ?>" type="text"/>
                <?php if ($icon) { ?>
                <i class="fa <?= $icon; ?> form-field-icon" style="color:<?= $iconColor; ?>;"></i>
                <?php } ?>
                <?php  if ($fieldHelp) { ?>
                <span style="<?= $colorDescription; ?>" class="help-block" ><?= $fieldHelp; ?></span>
                <?php } ?>
                <script type="text/javascript">
                require([
                    "jquery",
                    'mage/translate',
                    "mage/calendar"
                    ], function($,$t){
                    let max = null;
                    <?php if (!empty($maxDate)): ?>
                        max = new Date("<?= $maxDate; ?>");
                        <?php endif; ?>

                        $("#<?= $fieldId; ?>").calendar({
                            changeYear: true,
                            changeMonth: true,
                            yearRange: "c-90:c+90",
                            shortYearCutoff: "+10",
                            showButtonPanel: true,
                            currentText: $t('Go Today'),
                            closeText: $t('Close'),
                            showWeek: true,
                            buttonText: $t('Select Date'),
                            dateFormat: "<?= $dateFormat ?>",
                            maxDate: max,
                        });
                    });
                </script>
                </div>
            </div>
        </div>
</div>

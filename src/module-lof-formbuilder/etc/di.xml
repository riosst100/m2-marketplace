<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="formbuilder_form_listing_data_source" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Form\Grid\Collection</item>
                <item name="formbuilder_message_listing_data_source" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Message\Grid\Collection</item>
                <item name="formbuilder_reply_listing_data_source" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Reply\Grid\Collection</item>
                <item name="formbuilder_model_listing_data_source" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Model\Grid\Collection</item>
                <item name="formbuilder_modelcategory_listing_data_source" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Modelcategory\Grid\Collection</item>
                <item name="formbuilder_blacklist_listing_data_source" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Blacklist\Grid\Collection</item>
            </argument>
        </arguments>
    </type>
    <type name="Lof\Formbuilder\Model\ResourceModel\Form\Grid\Collection">
        <arguments>
            <argument name="mainTable" xsi:type="string">lof_formbuilder_form</argument>
            <argument name="eventPrefix" xsi:type="string">formbuilder_form_grid_collection</argument>
            <argument name="eventObject" xsi:type="string">form_grid_collection</argument>
            <argument name="resourceModel" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Form</argument>
        </arguments>
    </type>
    <type name="Lof\Formbuilder\Model\ResourceModel\Message\Grid\Collection">
        <arguments>
            <argument name="mainTable" xsi:type="string">lof_formbuilder_message</argument>
            <argument name="eventPrefix" xsi:type="string">formbuilder_message_grid_collection</argument>
            <argument name="eventObject" xsi:type="string">message_grid_collection</argument>
            <argument name="resourceModel" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Message</argument>
        </arguments>
    </type>
    <type name="Lof\Formbuilder\Model\ResourceModel\Reply\Grid\Collection">
        <arguments>
            <argument name="mainTable" xsi:type="string">lof_formbuilder_reply</argument>
            <argument name="eventPrefix" xsi:type="string">formbuilder_reply_grid_collection</argument>
            <argument name="eventObject" xsi:type="string">reply_grid_collection</argument>
            <argument name="resourceModel" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Reply</argument>
        </arguments>
    </type>
    <type name="Lof\Formbuilder\Model\ResourceModel\Model\Grid\Collection">
        <arguments>
            <argument name="mainTable" xsi:type="string">lof_formbuilder_model</argument>
            <argument name="eventPrefix" xsi:type="string">formbuilder_model_grid_collection</argument>
            <argument name="eventObject" xsi:type="string">model_grid_collection</argument>
            <argument name="resourceModel" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Model</argument>
        </arguments>
    </type>
    <type name="Lof\Formbuilder\Model\ResourceModel\Modelcategory\Grid\Collection">
        <arguments>
            <argument name="mainTable" xsi:type="string">lof_formbuilder_model_category</argument>
            <argument name="eventPrefix" xsi:type="string">formbuilder_modelcategory_grid_collection</argument>
            <argument name="eventObject" xsi:type="string">modelcategory_grid_collection</argument>
            <argument name="resourceModel" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Modelcategory</argument>
        </arguments>
    </type>
    <type name="Lof\Formbuilder\Model\ResourceModel\Blacklist\Grid\Collection">
        <arguments>
            <argument name="mainTable" xsi:type="string">lof_formbuilder_blacklist</argument>
            <argument name="eventPrefix" xsi:type="string">formbuilder_blacklist_grid_collection</argument>
            <argument name="eventObject" xsi:type="string">blacklist_grid_collection</argument>
            <argument name="resourceModel" xsi:type="string">Lof\Formbuilder\Model\ResourceModel\Blacklist</argument>
        </arguments>
    </type>
    <type name="Lof\Formbuilder\Helper\Data">
        <arguments>
            <argument name="barcodeGeneratorPNGClass" xsi:type="string">Picqer\Barcode\BarcodeGeneratorPNG</argument>
        </arguments>
    </type>
    <virtualType name="FormbuilderGirdFilterPool" type="Magento\Framework\View\Element\UiComponent\DataProvider\FilterPool">
        <arguments>
            <argument name="appliers" xsi:type="array">
                <item name="regular" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\RegularFilter</item>
                <item name="fulltext" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\FulltextFilter</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="FormGridDataProvider" type="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
        <arguments>
            <argument name="collection" xsi:type="object" shared="false">Magento\Cms\Model\ResourceModel\Form\Collection</argument>
            <argument name="filterPool" xsi:type="object" shared="false">FormbuilderGirdFilterPool</argument>
        </arguments>
    </virtualType>

    <type name="Lof\Formbuilder\Controller\AbstractIndex">
        <plugin name="authentication" type="Lof\Formbuilder\Controller\Index\Plugin" sortOrder="10"/>
    </type>

    <preference for="Lof\Formbuilder\Api\FormbuilderSettingManagementInterface" type="Lof\Formbuilder\Model\FormbuilderSettingManagement"/>
    <preference for="Lof\Formbuilder\Api\Data\FormbuilderInterface" type="Lof\Formbuilder\Model\Form"/>
    <preference for="Lof\Formbuilder\Api\Data\FieldOptionInterface" type="Lof\Formbuilder\Model\Data\FieldOption"/>
    <preference for="Lof\Formbuilder\Api\Data\SubmitFormFieldInterface" type="Lof\Formbuilder\Model\Data\SubmitFormField"/>
    <preference for="Lof\Formbuilder\Api\Data\SubmitFormInterface" type="Lof\Formbuilder\Model\Data\SubmitForm"/>
    <preference for="Lof\Formbuilder\Api\Data\FieldDesignInterface" type="Lof\Formbuilder\Model\Data\FieldDesign"/>
    <preference for="Lof\Formbuilder\Api\Data\FormbuilderDesignInterface" type="Lof\Formbuilder\Model\Data\FormDesign"/>
    <preference for="Lof\Formbuilder\Api\Data\FormbuilderSearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>
    <preference for="Lof\Formbuilder\Api\Data\FormbuilderMessageInterface" type="Lof\Formbuilder\Model\Message"/>
    <preference for="Lof\Formbuilder\Api\Data\FormbuilderMessageSearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>
    <preference for="Lof\Formbuilder\Api\FormbuilderManagementInterface" type="Lof\Formbuilder\Model\FormbuilderManagement"/>
    <preference for="Lof\Formbuilder\Api\FormbuilderRepositoryInterface" type="Lof\Formbuilder\Model\FormbuilderRepository"/>
    <preference for="Lof\Formbuilder\Api\SubmitFormRepositoryInterface" type="Lof\Formbuilder\Model\SubmitFormRepository"/>
</config>
